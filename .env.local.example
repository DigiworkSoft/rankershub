# Required environment variables for RankersHub Local Postgres

# ============================================================
# DATABASE CONFIGURATION (Local PostgreSQL)
# format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# ============================================================
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/rankershub

# ============================================================
# JWT SECRET — used to sign admin API tokens
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================================
JWT_SECRET=replace_with_a_long_random_64_char_secret

# ============================================================
# APP URL
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
