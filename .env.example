# ============================================================
# RankersHub Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values.
# cp .env.example .env.local

# ============================================================
# DATABASE (PostgreSQL connection string)
# Local: postgresql://postgres:password@localhost:5432/rankershub
# Supabase: postgresql://postgres.[ref]:[password]@[host]:6543/postgres
# ============================================================
DATABASE_URL=

# ============================================================
# JWT SECRET — used to sign admin API tokens
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================================
JWT_SECRET=

# ============================================================
# SITE URL (used in sitemap, robots, CSRF)
# ============================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# SUPABASE STORAGE (for blog/course image uploads)
# Get from: Supabase Dashboard → Settings → API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# OPTIONAL: Dev-only admin login bypass (NOT used in production)
# ============================================================
# ADMIN_USERNAME=
# ADMIN_PASSWORD=
